# 星喚 Beckon Stars 服務器環境變量
# 複製此文件為 .env（或在 shell 中 export）後填入你的實際值
# 只有標記為「必填」的變量必須設置，其他使用默認值即可

# ───────────────────────────────────────────────
# 服務器基礎配置（保持默認即可）
# ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8787
API_DB_PATH=./data/server-db.json
API_MAX_BODY_BYTES=24000000

# JWT 密鑰（生產環境必須設置固定值，否則每次重啟都會改變，已登入用戶會被踢出）
JWT_SECRET=your-strong-secret-key-here

# Google 登入（可選，Android APK 原生登入使用）
# 在 Google Cloud Console 建立 OAuth 2.0 Web client，填入 Client ID（不是 client secret）
# Android 的 google_web_client_id 必須使用同一個 Client ID
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# ───────────────────────────────────────────────
# Azure Speech to Text（語音轉文字）—— 必填
# ───────────────────────────────────────────────
# 前往 Azure Portal → Speech Services → 建立資源 → Keys and Endpoint
# Plan: Standard (S0)，每月包含 30 Audio hours，超量按 $1.2/小時計費
AZURE_STT_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_STT_KEY=your-azure-speech-key-here

# 舊版兼容名稱（可選，不建議使用）
# AZURE_SPEECH_KEY=your-azure-speech-key-here

# ───────────────────────────────────────────────
# OpenRouter（AI 摘要/總結）—— 必填
# ───────────────────────────────────────────────
# 前往 https://openrouter.ai/keys 創建 API Key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# 模型選擇（默認免費模型，可選）
OPENROUTER_MODEL=moonshotai/kimi-k2.6:free

# 識別來源（OpenRouter 要求，可選）
OPENROUTER_HTTP_REFERER=https://beckonstars.app
OPENROUTER_APP_TITLE=Beckon Stars

# ───────────────────────────────────────────────
# 舊版 LLM 配置（向後兼容，已廢棄）
# 不設置上述 Azure/OpenRouter 變量時才會使用
# ───────────────────────────────────────────────
# LLM_OPENAI_BASE_URL=https://fufu.iqach.top/v1
# LLM_SUMMARY_API_KEY=your-old-key
# LLM_SUMMARY_MODEL=mimo-v2.5
# LLM_TRANSCRIBE_MODEL=mimo-v2-omni
